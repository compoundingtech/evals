// ghost-bug.kdl — the whole eval in one file.  `st2 eval ./` runs it; `st2 up ./` just boots the team.
// A debug loop: a subtle shared-default-mutation bug in `labelkit` (format.js mutates the shared
// defaultOptions). The suite is GREEN because it never formats with defaults AFTER a custom call, so the
// bug is a ghost. The team must reproduce -> ROOT-cause (a non-mutating merge, not a band-aid) -> add a
// mutation-valid regression test. All judges are held-out.

env {                                    // cascades: agents + their processes inherit these
  ST_ROOT  "$CATALOG/smalltalk"
  PTY_ROOT "$CATALOG/pty"
}

team "gb" {                              // prefixes the agents it holds -> gb.sup, gb.fix
  agent "sup" {
    workspace "./sup"                    // coordinate-only cwd (owns no product repo)
    env { ST_AGENT "gb.sup" }
    command #"exec claude --permission-mode bypassPermissions 'You just cold-started. Run your boot ritual (set status available, drain inbox), then stand by for work via ding.'"#
    /- ding {}
    exec "gb.sup.ding" { command #"st2 ding gb.sup --identity gb.sup --root $CATALOG/smalltalk"# }
  }
  agent "fix" {
    workspace "./worker"                 // owns the labelkit repo (this dir)
    env { ST_AGENT "gb.fix" }
    command #"exec claude --permission-mode auto 'You just cold-started. Run your boot ritual (set status available, drain inbox), then stand by for work via ding.'"#
    /- ding {}
    exec "gb.fix.ding" { command #"st2 ding gb.fix --identity gb.fix --root $CATALOG/smalltalk"# }
  }
}

eval {                                   // `st2 eval` = copy the world, boot the team, kick off, then judge
  copy "./fixture"                       // pre-built starting world, 1:1 (worker/_git -> worker/.git on copy)
  message {                              // kickoff — same as `st2 message send`
    from "requester"
    to "gb.sup"
    content "./task.md"
  }
  max-timeout "1200s"                    // the whole eval must finish within this

  judges {                               // all must pass; each one visible, nothing magic (all mechanical here)
    judge "isolation — only gb.fix authored; supervisor owns no repo; change stays in src/test/package/README" {
      exec "bash ./judges/isolation.sh"
    }
    judge "visible suite is green on HEAD" {
      exec "bash ./judges/suite.sh"
    }
    judge "root cause — the shared-default mutation is gone (behavior + no-mutation probes, blind to how)" {
      exec "bash ./judges/root-cause.sh"
    }
    judge "regression test is mutation-valid — RED on the buggy BASE src" {
      exec "bash ./judges/regression.sh"
    }
    judge "coordination — delegate->report visible on the bus" {
      exec "bash ./judges/coordination.sh"
    }
  }
}
